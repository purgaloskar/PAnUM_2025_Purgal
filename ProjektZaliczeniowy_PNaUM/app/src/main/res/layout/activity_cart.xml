<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F8FF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TWÓJ KOSZYK"
        android:textSize="26sp"
        android:textColor="#1A365D"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/tv_podsumowanie"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:text="Koszyk jest pusty." />

    <Button
        android:id="@+id/btn_zamow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WYŚLIJ ZAMÓWIENIE"
        android:backgroundTint="#89CFF0"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="16dp"
        android:padding="14dp" />

    <Button
        android:id="@+id/btn_powrot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="POWRÓT DO MENU"
        android:backgroundTint="#555555"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="8dp"
        android:padding="14dp" />

</LinearLayout>