<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F4F9FD"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#64B5F6"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CoffeeTime"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/lvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#D1E4F2"
        android:dividerHeight="1dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSelectProduct"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Wybierz produkt z listy"
        android:backgroundTint="#1E3A60"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ilość (max 3 cyfry)"
        android:inputType="none"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnAddToCart"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="DODAJ DO KOSZYKA"
        android:backgroundTint="#64B5F6"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4">

            <Button android:id="@+id/btnKey1" android:text="1" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey2" android:text="2" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey3" android:text="3" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />

            <Button android:id="@+id/btnKey4" android:text="4" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey5" android:text="5" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey6" android:text="6" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />

            <Button android:id="@+id/btnKey7" android:text="7" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey8" android:text="8" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKey9" android:text="9" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />

            <View android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" />
            <Button android:id="@+id/btnKey0" android:text="0" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#1E3A60" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnKeyDel" android:text="DEL" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="45dp" android:backgroundTint="#D32F2F" android:textColor="#FFFFFF" />
        </GridLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="POWRÓT"
            android:backgroundTint="#64B5F6"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSubmitFromMain"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="ZŁÓŻ ZAMÓWIENIE"
            android:backgroundTint="#1E3A60"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>