<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arabskie -> Rzymskie"
            android:textSize="24sp"/>

        <EditText
            android:id="@+id/etArabskie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Podaj liczbę 1-3999"
            android:inputType="number"/>

        <Button
            android:id="@+id/btnArabskie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konwertuj"/>

        <TextView
            android:id="@+id/tvRzymskiWynik"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rzymskie -> Arabskie"
            android:textSize="24sp"/>

        <EditText
            android:id="@+id/etRzymskie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Podaj liczbę rzymską"/>

        <Button
            android:id="@+id/btnRzymskie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konwertuj"/>

        <TextView
            android:id="@+id/tvArabskiWynik"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"/>

    </LinearLayout>

</ScrollView>